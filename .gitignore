# pyenv
#   For a library or package, you might want to ignore these files since the values are
#   specific to the developer's system of choice. But in a hackathon setting we ignore it:
.python-version

# pipenv
#   According to pypa/pipenv#1263, we should ignore Pipfile.lock if we are developing
#   an application rather than a library.
# Pipfile.lock

# poetry
#   Similarly, in common environments poetry.lock can be ignored/tracked depending on team preference.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, PDM's lockfile can be ignored/tracked depending on preference.
# pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/

