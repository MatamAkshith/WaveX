# Database Configuration (SQLite by default — zero setup; swap to Postgres for prod)
DATABASE_URL=sqlite:///./wavex.db

# API Keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Database firewall: set to enable X-API-Key auth on all data routes
# API_KEY=choose-a-strong-key
# ALLOWED_ORIGINS=http://localhost:5173

# JWT authentication (generate a key: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Vector DB Configuration
CHROMA_DB_PATH=./chroma_db

# Application Configuration
ENVIRONMENT=development
DEBUG=True
